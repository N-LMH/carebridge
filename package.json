{
  "name": "carebridge",
  "version": "1.0.0",
  "description": "CareBridge healthcare triage assistant MVP",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:client": "vite",
    "build:client": "vite build",
    "preview:client": "vite preview",
    "type-check": "vue-tsc -p client/tsconfig.json --noEmit",
    "build": "npm run type-check && npm run build:client",
    "build:deck": "node scripts/generate-pitch-deck.mjs",
    "capture:screenshots": "node scripts/capture-screenshots.mjs",
    "build:pdf": "python scripts/generate_hackathon_pdf.py",
    "test": "npm run test:coverage && npm run test:e2e",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "express": "^5.1.0",
    "pinia": "^3.0.4",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^3.2.4",
    "pptxgenjs": "^4.0.1",
    "supertest": "^7.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.4",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  }
}
